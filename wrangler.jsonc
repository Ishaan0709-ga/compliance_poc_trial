{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "complyos",
  "compatibility_date": "2026-06-19",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "assets": {
    "directory": ".output/public",
  },
  "observability": {
    "enabled": true,
  },
}
